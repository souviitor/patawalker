# PataWalker — Variáveis de Ambiente
# Copie para .env e preencha com seus valores

# Segurança (use uma string longa e aleatória)
SECRET_KEY=change-me-to-a-long-random-string

# Banco de dados PostgreSQL
DATABASE_URL=postgresql://dogwalker_user:dogwalker_pass@localhost:5432/dogwalker_db

# Mercado Pago (obtenha em mercadopago.com.br/developers)
MP_ACCESS_TOKEN=APP_USR-seu-access-token-aqui
MP_PUBLIC_KEY=APP_USR-sua-public-key-aqui

# Admin
ADMIN_EMAIL=admin@patawalker.com.br

# Ambiente
FLASK_ENV=production

